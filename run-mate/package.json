{
  "name": "run-mate-script-runner",
  "displayName": "RunMate - Script Runner",
  "description": "Quick script runner with intelligent status bar buttons for package.json scripts. Auto-detects npm, pnpm, yarn, and bun with multi-root workspace support.",
  "version": "1.0.5",
  "publisher": "SanekxArcs",
  "license": "MIT",
  "icon": "assets/icon-128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/SanekxArcs/my-vscode-extention/tree/main/run-mate"
  },
  "homepage": "https://github.com/SanekxArcs/my-vscode-extention/blob/main/run-mate/README.md",
  "bugs": {
    "url": "https://github.com/SanekxArcs/my-vscode-extention/issues"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "workspace"
  ],
  "scripts": {
    "build": "vsce package",
    "push": "vsce publish"
  },
  "keywords": [
    "npm",
    "pnpm",
    "yarn",
    "bun",
    "scripts",
    "tasks",
    "runner",
    "quick-launch"
  ],
  "activationEvents": [
    "onCommand:run-mate-script-runner.showAllScripts",
    "onCommand:run-mate-script-runner.stopRunningScripts",
    "workspaceContains:package.json",
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "dependencies": {
    "jsonc-parser": "^3.2.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "run-mate-script-runner.stopRunningScripts",
        "title": "Stop Running Scripts",
        "category": "RunMate"
      },
      {
        "command": "run-mate-script-runner.showAllScripts",
        "title": "Show All Scripts",
        "category": "RunMate"
      }
    ],
    "keybindings": [
      {
        "command": "run-mate-script-runner.showAllScripts",
        "key": "ctrl+alt+q"
      }
    ],
    "configuration": [
      {
        "title": "run-mate-script-runner",
        "properties": {
          "run-mate-script-runner.useDynamicScriptParsing": {
            "type": "boolean",
            "default": true,
            "description": "Enable dynamic status bar buttons generated from package.json scripts."
          },
          "run-mate-script-runner.workspaceMode": {
            "type": "string",
            "enum": [
              "first",
              "pick",
              "all"
            ],
            "default": "first",
            "description": "How to handle multi-root workspaces when building buttons: first folder, pick per run, or all folders."
          },
          "run-mate-script-runner.excludeScripts": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "test",
              "postinstall",
              "preinstall"
            ],
            "description": "List of scripts to ignore when generating status bar buttons."
          },
          "run-mate-script-runner.maxDynamicScriptButtons": {
            "type": "number",
            "default": 8,
            "minimum": 0,
            "description": "Maximum number of script buttons shown before collapsing into an overflow menu."
          },
          "run-mate-script-runner.scriptOrder": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "dev",
              "start",
              "build",
              "test",
              "lint"
            ],
            "description": "Priority order for scripts. Scripts listed here will appear first."
          },
          "run-mate-script-runner.reuseTerminalForScripts": {
            "type": "boolean",
            "default": true,
            "description": "Reuse dedicated terminals per script instead of creating a new terminal each time."
          },
          "run-mate-script-runner.askBeforeKill": {
            "type": "boolean",
            "default": true,
            "description": "Ask for confirmation before stopping a running script when re-running from the status bar."
          }
        }
      }
    ]
  }
}
