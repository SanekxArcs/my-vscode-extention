{
  "name": "vc-mate",
  "displayName": "VC-Mate",
  "description": "Convert CSS length units between px/rem and vw/vh with smart status bar utilities.",
  "version": "1.0.0",
  "publisher": "SanekxArcs",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/SanekxArcs/my-vscode-extention/tree/main/viewport-converter"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:vc-mate.convertToViewportUnit",
    "onCommand:vc-mate.reverseConvertFromViewportUnit",
    "onCommand:vc-mate.convertHereQuick",
    "onCommand:vc-mate.convertCycleVW",
    "onCommand:vc-mate.convertCycleVH",
    "onCommand:vc-mate.cycleViewportScreen",
    "onCommand:vc-mate.viewportSettingsQuick"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vc-mate.convertToViewportUnit",
        "title": "VC-Mate: Convert CSS unit to vw/vh"
      },
      {
        "command": "vc-mate.reverseConvertFromViewportUnit",
        "title": "VC-Mate: Convert vw/vh to px/rem"
      },
      {
        "command": "vc-mate.convertHereQuick",
        "title": "VC-Mate: Convert Selection"
      },
      {
        "command": "vc-mate.convertCycleVW",
        "title": "VC-Mate: Convert Cycle (vw)"
      },
      {
        "command": "vc-mate.convertCycleVH",
        "title": "VC-Mate: Convert Cycle (vh)"
      },
      {
        "command": "vc-mate.cycleTailwindUnit",
        "title": "VC-Mate: Cycle Tailwind (px -> rem -> tw)"
      },
      {
        "command": "vc-mate.cycleViewportScreen",
        "title": "VC-Mate: Cycle Viewport Screen"
      },
      {
        "command": "vc-mate.viewportSettingsQuick",
        "title": "VC-Mate: Viewport Settings"
      },
      {
        "command": "vc-mate.toggleBrackets",
        "title": "VC-Mate: Toggle Brackets"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vc-mate.convertToViewportUnit",
          "when": "editorTextFocus",
          "group": "navigation@9"
        },
        {
          "command": "vc-mate.reverseConvertFromViewportUnit",
          "when": "editorTextFocus",
          "group": "navigation@10"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vc-mate.convertToViewportUnit",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorTextFocus"
      },
      {
        "command": "vc-mate.reverseConvertFromViewportUnit",
        "key": "ctrl+alt+shift+v",
        "mac": "cmd+alt+shift+v",
        "when": "editorTextFocus"
      },
      {
        "command": "vc-mate.convertCycleVW",
        "key": "alt+v",
        "when": "editorTextFocus"
      },
      {
        "command": "vc-mate.convertCycleVH",
        "key": "alt+h",
        "when": "editorTextFocus"
      },
      {
        "command": "vc-mate.cycleTailwindUnit",
        "key": "alt+z",
        "when": "editorTextFocus"
      },
      {
        "command": "vc-mate.cycleViewportScreen",
        "key": "alt+x",
        "when": "editorTextFocus || editorFocus"
      }
    ],
    "codeActions": [
      {
        "languages": [
          "css",
          "scss",
          "sass",
          "less",
          "javascript",
          "typescript",
          "javascriptreact",
          "typescriptreact"
        ],
        "actions": [
          {
            "kind": "refactor.rewrite.viewport",
            "title": "Convert to vw/vh",
            "command": "vc-mate.convertToViewportUnit"
          },
          {
            "kind": "refactor.rewrite.viewport.reverse",
            "title": "Convert vw/vh to px/rem",
            "command": "vc-mate.reverseConvertFromViewportUnit"
          }
        ]
      }
    ],
    "configuration": [
      {
        "title": "VC-Mate",
        "properties": {
          "vc-mate.viewportScreens": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "360x800",
              "375x812",
              "390x844",
              "414x896",
              "428x926",
              "768x1024",
              "800x1280",
              "1024x1366",
              "1280x800",
              "1366x768",
              "1440x900",
              "1536x864",
              "1600x900",
              "1920x1080",
              "2160x1440",
              "2560x1440"
            ],
            "description": "List of target screens in WIDTHxHEIGHT format used for vw/vh conversion."
          },
          "vc-mate.baseFontSize": {
            "type": "number",
            "default": 16,
            "minimum": 1,
            "description": "Base font size in pixels used to convert rem to px (1rem = baseFontSize px)."
          },
          "vc-mate.viewportPrecision": {
            "type": "number",
            "default": 4,
            "minimum": 0,
            "maximum": 8,
            "description": "Number of decimal places to keep when converting to vw/vh."
          },
          "vc-mate.defaultOutputUnit": {
            "type": "string",
            "enum": [
              "px",
              "rem"
            ],
            "default": "px",
            "description": "Default unit for reverse conversion (vw/vh to px or rem)."
          },
          "vc-mate.autoDetectViewportAxis": {
            "type": "boolean",
            "default": true,
            "description": "Auto-detect vw/vh from CSS property (e.g., width→vw, height→vh) and skip the unit prompt."
          },
          "vc-mate.lastUsedViewportUnit": {
            "type": "string",
            "enum": [
              "vw",
              "vh"
            ],
            "default": "vw",
            "description": "Last used viewport unit (vw or vh) - automatically updated when you convert."
          },
          "vc-mate.lastUsedScreen": {
            "type": "string",
            "default": "1440x900",
            "description": "Last used screen resolution - automatically updated when you convert."
          },
          "vc-mate.showViewportStatusBar": {
            "type": "boolean",
            "default": true,
            "description": "Show the viewport screen, base font size, and precision status bar button."
          },
          "vc-mate.useBrackets": {
            "type": "boolean",
            "default": true,
            "description": "Whether to use brackets [] for Tailwind conversion (e.g., [10px] vs 10px)."
          },
          "vc-mate.showConvertHereButton": {
            "type": "boolean",
            "default": true,
            "description": "Show the 'Convert Here' button in the status bar."
          },
          "vc-mate.showViewportInfo": {
            "type": "boolean",
            "default": true,
            "description": "Show the viewport screen/base info in the status bar."
          },
          "vc-mate.showBracketToggle": {
            "type": "boolean",
            "default": true,
            "description": "Show the brackets toggle button in the status bar."
          }
        }
      }
    ]
  }
}
